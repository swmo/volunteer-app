{% extends 'base.html.twig' %}

{% block title %}Volunteer App{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;700&family=DM+Serif+Display&display=swap');

  :root {
    --bg: #f7f5ef;
    --ink: #1d2a35;
    --ink-soft: #4f6170;
    --brand: #de5a2a;
    --brand-dark: #aa3f1a;
    --card: rgba(255, 255, 255, 0.72);
    --line: rgba(29, 42, 53, 0.12);
  }

  .home-shell {
    min-height: 100vh;
    color: var(--ink);
    background:
      radial-gradient(circle at 16% 12%, rgba(245, 170, 90, 0.34), transparent 33%),
      radial-gradient(circle at 90% 8%, rgba(86, 134, 200, 0.24), transparent 30%),
      linear-gradient(145deg, #f5f0e5 0%, var(--bg) 45%, #f0f7fb 100%);
  }

  .home-wrap {
    max-width: 1160px;
    margin: 0 auto;
    padding: 1.2rem 1rem 4rem;
  }

  .home-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .home-mark {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.86rem;
    color: var(--ink-soft);
  }

  .home-login {
    display: inline-block;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(135deg, var(--brand), var(--brand-dark));
    font-family: 'Nunito', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    box-shadow: 0 8px 20px rgba(170, 63, 26, 0.25);
  }

  .home-hero {
    margin-top: 1.4rem;
    padding: 2.25rem 1.8rem;
    border: 1px solid var(--line);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(4px);
    animation: rise 450ms ease-out both;
  }

  .home-hero h1 {
    margin: 0;
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.08;
    max-width: 12ch;
  }

  .home-hero p {
    margin: 1rem 0 0;
    max-width: 56ch;
    color: var(--ink-soft);
    font-family: 'Nunito', sans-serif;
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .home-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 1.1rem;
  }

  .org-card {
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: var(--card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: rise 500ms ease-out both;
  }

  .org-card:nth-child(2) { animation-delay: 60ms; }
  .org-card:nth-child(3) { animation-delay: 120ms; }
  .org-card:nth-child(4) { animation-delay: 180ms; }

  .org-flag {
    height: 0.45rem;
    background: linear-gradient(90deg, #ea7c4a, #f3c06b 60%, #7ca8d9);
  }

  .org-body {
    padding: 1.05rem 1rem 1rem;
    font-family: 'Nunito', sans-serif;
  }

  .org-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .org-meta {
    margin-top: 0.55rem;
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .org-projects {
    margin-top: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .org-pill {
    display: inline-block;
    border: 1px solid rgba(29, 42, 53, 0.2);
    border-radius: 999px;
    padding: 0.36rem 0.64rem;
    color: var(--ink);
    text-decoration: none;
    font-size: 0.83rem;
    background: rgba(255, 255, 255, 0.72);
    transition: transform 120ms ease, background 120ms ease;
  }

  .org-pill:hover {
    transform: translateY(-1px);
    background: #fff;
  }

  .org-empty {
    margin-top: 0.75rem;
    font-size: 0.84rem;
    color: #7d8e9b;
  }

  .home-source {
    margin-top: 1.8rem;
    text-align: center;
    font-family: 'Nunito', sans-serif;
    color: var(--ink-soft);
  }

  .home-source a {
    color: var(--ink);
    text-decoration: none;
    font-weight: 700;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .home-wrap { padding-left: 0.8rem; padding-right: 0.8rem; }
    .home-hero { padding: 1.4rem 1rem; }
  }
</style>

<main class="home-shell">
  <div class="home-wrap">
    <header class="home-topbar">
      <span class="home-mark">Volunteer App</span>
      <a class="home-login" href="{{ path('app_login') }}">Admin Login</a>
    </header>

    <section class="home-hero">
      <h1>Find volunteers for your next event.</h1>
      <p>
        Open-source volunteer management for clubs and organizations.
        Choose an organization below and jump straight into an active project.
      </p>
    </section>

    <section class="home-grid">
      {% for organisation in organisations %}
        <article class="org-card">
          <div class="org-flag"></div>
          <div class="org-body">
            <h2 class="org-title">{{ organisation.name }}</h2>
            <p class="org-meta">
              {{ organisation.projects|length }} projects · {{ organisation.people|length }} volunteers
            </p>
            <div class="org-projects">
              {% for project in organisation.projects %}
                {% if project.isEnabled %}
                  <a class="org-pill" href="{{ path('volunteer_enroll_by_project', {'id': project.id}) }}">
                    {{ project.name }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
            {% set hasEnabledProject = false %}
            {% for project in organisation.projects %}
              {% if project.isEnabled %}
                {% set hasEnabledProject = true %}
              {% endif %}
            {% endfor %}
            {% if not hasEnabledProject %}
              <p class="org-empty">No active projects right now.</p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </section>

    <p class="home-source">
      Built as open source. <a target="_blank" href="https://github.com/swmo/volunteer-app">View on GitHub</a>
    </p>
  </div>
</main>
{% endblock %}
