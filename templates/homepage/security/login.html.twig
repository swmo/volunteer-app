{% extends 'base.html.twig' %}

{% block title %}Admin Login{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;700&family=DM+Serif+Display&display=swap');

  :root {
    --bg: #f7f5ef;
    --ink: #1d2a35;
    --ink-soft: #4f6170;
    --brand: #de5a2a;
    --brand-dark: #aa3f1a;
    --card: rgba(255, 255, 255, 0.76);
    --line: rgba(29, 42, 53, 0.14);
    --danger: #b93a32;
  }

  .login-shell {
    min-height: 100vh;
    color: var(--ink);
    background:
      radial-gradient(circle at 14% 12%, rgba(245, 170, 90, 0.34), transparent 32%),
      radial-gradient(circle at 90% 8%, rgba(86, 134, 200, 0.24), transparent 30%),
      linear-gradient(145deg, #f5f0e5 0%, var(--bg) 45%, #f0f7fb 100%);
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .login-card {
    width: min(100%, 430px);
    border: 1px solid var(--line);
    border-radius: 1.1rem;
    background: var(--card);
    backdrop-filter: blur(4px);
    box-shadow: 0 24px 45px rgba(29, 42, 53, 0.1);
    padding: 1.35rem;
    animation: rise 420ms ease-out both;
  }

  .login-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font: 700 0.78rem 'Nunito', sans-serif;
    color: var(--ink-soft);
  }

  .login-title {
    margin: 0.45rem 0 0;
    font: 600 clamp(1.75rem, 4.5vw, 2.3rem) 'DM Serif Display', serif;
    line-height: 1.08;
  }

  .login-sub {
    margin: 0.75rem 0 0;
    font: 400 0.95rem/1.55 'Nunito', sans-serif;
    color: var(--ink-soft);
  }

  .login-error {
    margin-top: 1rem;
    border: 1px solid rgba(185, 58, 50, 0.35);
    background: rgba(185, 58, 50, 0.08);
    color: var(--danger);
    border-radius: 0.65rem;
    padding: 0.7rem 0.8rem;
    font: 500 0.88rem/1.4 'Nunito', sans-serif;
  }

  .login-form {
    margin-top: 1rem;
  }

  .login-field {
    display: block;
    margin-top: 0.9rem;
  }

  .login-label {
    display: block;
    margin-bottom: 0.4rem;
    font: 600 0.88rem 'Nunito', sans-serif;
    color: var(--ink);
  }

  .login-input {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 0.7rem;
    padding: 0.62rem 0.75rem;
    font: 500 0.95rem 'Nunito', sans-serif;
    background: rgba(255, 255, 255, 0.95);
    color: var(--ink);
  }

  .login-input:focus {
    outline: none;
    border-color: rgba(222, 90, 42, 0.6);
    box-shadow: 0 0 0 3px rgba(222, 90, 42, 0.15);
  }

  .login-actions {
    margin-top: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
  }

  .login-button {
    border: 0;
    border-radius: 999px;
    padding: 0.62rem 1.05rem;
    background: linear-gradient(135deg, var(--brand), var(--brand-dark));
    color: #fff;
    cursor: pointer;
    font: 700 0.9rem 'Nunito', sans-serif;
    box-shadow: 0 8px 20px rgba(170, 63, 26, 0.25);
  }

  .login-link {
    color: var(--ink-soft);
    text-decoration: none;
    font: 600 0.84rem 'Nunito', sans-serif;
  }

  .login-link:hover { color: var(--ink); }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<main class="login-shell">
  <section class="login-card">
    <p class="login-kicker">Volunteer App</p>
    <h1 class="login-title">Admin Login</h1>
    <p class="login-sub">Sign in to manage projects, volunteers and enrollments.</p>

    {% if error %}
      <div class="login-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post" class="login-form">
      <label class="login-field">
        <span class="login-label">E-mail</span>
        <input
          type="email"
          value="{{ last_username }}"
          name="email"
          id="inputEmail"
          class="login-input"
          placeholder="name@example.com"
          required
          autofocus
        >
      </label>

      <label class="login-field">
        <span class="login-label">Password</span>
        <input
          type="password"
          name="password"
          id="inputPassword"
          class="login-input"
          placeholder="Your password"
          required
        >
      </label>

      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

      <div class="login-actions">
        <a class="login-link" href="{{ path('home') }}">Back to homepage</a>
        <button class="login-button" type="submit">Sign in</button>
      </div>
    </form>
  </section>
</main>
{% endblock %}
