{% if app.user.getSelectedOrganisation() %}
    <nav class="admin-nav">
        <ul class="admin-nav-list">
            <li>
                <a class="admin-nav-link" href="{{ path('admin_organisation_list') }}">
                    <i class="fas fa-building"></i>
                    {{ app.user.getSelectedOrganisation().name }} (ID: {{ app.user.getSelectedOrganisation().id }})
                </a>
            </li>
            <li><a class="admin-nav-link" href="{{ path('admin_dashboard') }}"><i class="fas fa-chart-line"></i>Dashboard</a></li>
            <li><a class="admin-nav-link" href="{{ path('admin_project_list') }}"><i class="fas fa-layer-group"></i>Projekte</a></li>
            <li><a class="admin-nav-link" href="{{ path('admin_person_list') }}"><i class="fas fa-comments"></i>Kommunikation</a></li>
            <li><a class="admin-nav-link" href="{{ path('admin_person_list') }}"><i class="fas fa-address-book"></i>Stammdaten</a></li>
            <li><a class="admin-nav-link" href="{{ path('admin_user_list') }}"><i class="fas fa-users-cog"></i>Benutzer</a></li>
            <li><a class="admin-nav-link" href="{{ path('admin_log_list') }}"><i class="fas fa-stream"></i>Logs</a></li>
        </ul>
    </nav>
{% else %}
    <nav class="admin-nav">
        <ul class="admin-nav-list">
            <li>
                <a class="admin-nav-link" href="{{ path('admin_organisation_list') }}">
