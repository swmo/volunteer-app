{% extends 'admin/base.html.twig' %}

{% block title %}Anmeldung bearbeiten{% endblock %}

{% block main %}
<div class="admin-form-card">
  <div class="form-header">
    <h1>Anmeldung bearbeiten</h1>
    <p class="form-help">Bearbeite Personendaten und Einsatzzuweisungen in einem Schritt.</p>
  </div>
  {{ form_start(form) }}
    {{ form_widget(form) }}
    <div class="form-actions">
      <button type="submit" class="btn">Speichern</button>
    </div>
  {{ form_end(form) }}
</div>

<div class="admin-form-card mt-4">
  <div class="form-header">
    <h2>Aenderungslog</h2>
    <p class="form-help">Die letzten Aenderungen an dieser Anmeldung.</p>
  </div>
  {% if logEntries is empty %}
    <div class="empty-state">Noch keine Aenderungen vorhanden.</div>
  {% else %}
    <div class="table-wrap">
      <table class="admin-log-table">
        <thead>
          <tr>
            <th>Datum</th>
            <th>Benutzer</th>
            <th>ObjektClass</th>
            <th>ObjektId</th>
            <th>Action</th>
            <th>Version</th>
            <th>Daten</th>
          </tr>
        </thead>
        <tbody>
          {% for logEntry in logEntries %}
            <tr>
              <td>{{ logEntry.loggedAt ? logEntry.loggedAt|date('Y-m-d H:i') : '-' }}</td>
              <td>{{ logEntry.username ?: 'System' }}</td>
              <td>{{ logEntry.objectClass ?: '-' }}</td>
              <td>{{ logEntry.objectId ?: '-' }}</td>
              <td>{{ logEntry.action ?: '-' }}</td>
              <td>{{ logEntry.version ?: '-' }}</td>
              <td>
                {% if logEntry.data is empty %}
                  -
                {% else %}
                  <pre class="json-preview">{{ logEntry.data|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
{% endblock %}
