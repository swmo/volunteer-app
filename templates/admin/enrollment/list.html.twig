{% extends 'admin/base.html.twig' %}

{% block title %}Anmeldungen{% endblock %}

{% block main %}
<style>
  .admin-filter-bar {
    align-items: end;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: minmax(14rem, 24rem) auto auto;
    margin-bottom: 1rem;
  }

  .admin-filter-field {
    display: grid;
    gap: 0.38rem;
  }

  @media (max-width: 720px) {
    .admin-filter-bar {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="admin-form-card">
  <div class="page-header">
    <div>
      <h1>Anmeldungen</h1>
      <p class="page-subtitle"><a href="{{ path('admin_project_list') }}">Projekte</a> -> {{ project.name }}</p>
    </div>
    <div class="page-actions">
      <a class="link-btn" href="{{ path('admin_enrollment_export', {type: 'overview', project: project.id}) }}">
        <i class="fas fa-file-excel"></i> Excel Export
      </a>
    </div>
  </div>

  <form method="get" class="admin-filter-bar">
    <div class="admin-filter-field">
      <label for="mission-filter">Einsatzort</label>
      <select id="mission-filter" name="mission">
        <option value="">Alle Einsatzorte</option>
        {% for mission in missions %}
          <option value="{{ mission.id }}" {% if selectedMissionId == mission.id %}selected{% endif %}>
            {{ mission.name }}
          </option>
        {% endfor %}
      </select>
    </div>
    <button class="link-btn primary" type="submit"><i class="fas fa-filter"></i> Filtern</button>
    {% if selectedMissionId %}
      <a class="link-btn" href="{{ path('admin_enrollment_list_by_project', {id: project.id}) }}">Filter zurücksetzen</a>
    {% endif %}
  </form>

  {% if enrollments is empty %}
    <div class="empty-state">
      {% if selectedMissionId %}
        Keine Anmeldungen für diesen Einsatzort gefunden.
      {% else %}
        Keine Anmeldungen für dieses Projekt vorhanden.
      {% endif %}
    </div>
  {% else %}
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Vorname</th>
            <th>Nachname</th>
            <th>E-Mail</th>
            <th>Mobile</th>
            <th>Einsätze</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          {% for enrollment in enrollments %}
            <tr>
              <td>{{ enrollment.firstname }}</td>
              <td>{{ enrollment.lastname }}</td>
              <td>{{ enrollment.email }}</td>
              <td>{{ enrollment.mobile }}</td>
              <td>
                {% if enrollment.missionChoice01 %}
                  {{ enrollment.missionChoice01.name }}<br>
                {% endif %}
                {% if enrollment.missionChoice02 %}
                  {{ enrollment.missionChoice02.name }}<br>
                {% endif %}
                {{ enrollment.getWorkingTime|date('%h:%i') }}
              </td>
              <td>
                <a class="link-btn" href="{{ path('admin_enrollment_edit', {id: enrollment.id}) }}">Edit</a>
                <a class="link-btn" href="{{ path('admin_enrollment_delete', {id: enrollment.id}) }}" onclick="return confirm('Anmeldung wirklich löschen?');">Löschen</a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>

{% endblock %}
