{% extends 'admin/base.html.twig' %}

{% block title %}Stammdaten{% endblock %}

{% block main %}
<div class="admin-form-card">
  <div class="page-header">
    <div>
      <h1>Stammdaten</h1>
      <p class="page-subtitle">Verwaltung aller Personen und Kontaktinformationen.</p>
    </div>
    <div class="page-actions">
      <a class="link-btn" href="{{ path('admin_person_emailgroup') }}"><i class="fas fa-envelope"></i> Emailgruppe</a>
      <a class="link-btn" target="_blank" href="{{ path('admin_person_export') }}"><i class="fas fa-file-excel"></i> Excel Export</a>
    </div>
  </div>

  {% if persons is empty %}
    <div class="empty-state">Keine Personen vorhanden.</div>
  {% else %}
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Adresse</th>
            <th>Kontakt</th>
            <th>Bemerkung</th>
            <th>Aktionen</th>
          </tr>
        </thead>
        <tbody>
          {% for person in persons %}
            <tr>
              <td>{{ person.id }}</td>
              <td>{{ person.lastname }} {{ person.firstname }}</td>
              <td>{{ person.street }}<br>{{ person.zip }} {{ person.city }}</td>
              <td>{{ person.mobile }}<br>{{ person.email }}</td>
              <td>{{ person.remark }}</td>
              <td>
                <div class="page-actions">
                  <a class="link-btn" href="{{ path('admin_person_edit', {id: person.id}) }}">Edit</a>
                  <a class="link-btn" href="{{ path('admin_person_delete', {id: person.id}) }}">Delete</a>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
{% endblock %}
