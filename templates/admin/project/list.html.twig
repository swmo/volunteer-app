{% extends 'admin/base.html.twig' %}

{% block title %}Projekte{% endblock %}

{% block main %}
<div class="admin-form-card">
  <div class="page-header">
    <div>
      <h1>Projekte</h1>
      <p class="page-subtitle">Übersicht über alle Projekte und direkte Zugriffe auf Einsätze und Anmeldungen.</p>
    </div>
    <div class="page-actions">
      <a class="link-btn primary" href="{{ path('admin_project_create') }}">
        <i class="fas fa-plus"></i> Neues Projekt
      </a>
    </div>
  </div>

  {% if projects is empty %}
    <div class="empty-state">Keine Projekte vorhanden.</div>
  {% else %}
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Projekt</th>
            <th>Organisation</th>
            <th>Einsätze</th>
            <th>Anmeldungen</th>
            <th>Bearbeiten</th>
          </tr>
        </thead>
        <tbody>
          {% for project in projects %}
            <tr>
              <td>
                {% if project.isEnabled %}
                  <span class="badge enabled"><i class="fas fa-check-circle"></i> Aktiv</span>
                {% else %}
                  <span class="badge disabled"><i class="fas fa-times-circle"></i> Inaktiv</span>
                {% endif %}
              </td>
              <td>{{ project.id }} {{ project.name }}</td>
              <td>{{ project.organisation.name }}</td>
              <td><a class="link-btn" href="{{ path('admin_mission_list_by_project', {id: project.id}) }}">Einsätze</a></td>
              <td><a class="link-btn" href="{{ path('admin_enrollment_list_by_project', {id: project.id}) }}">Anmeldungen</a></td>
              <td><a class="link-btn" href="{{ path('admin_project_edit', {id: project.id}) }}">Edit</a></td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>

{% endblock %}
