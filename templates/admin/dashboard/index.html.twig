{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block main %}
    <style>
        .dashboard-layout {
            display: grid;
            gap: 0.95rem;
        }

        .dashboard-hero {
            border: 1px solid var(--line);
            border-radius: 0.95rem;
            padding: 1rem;
            background:
                radial-gradient(circle at 82% 12%, rgba(86, 134, 200, 0.16), transparent 46%),
                radial-gradient(circle at 18% 78%, rgba(222, 90, 42, 0.16), transparent 48%),
                rgba(255, 255, 255, 0.88);
        }

        .dashboard-kpis {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .dashboard-kpi {
            border: 1px solid var(--line);
            border-radius: 0.85rem;
            padding: 0.8rem;
            background: rgba(255, 255, 255, 0.9);
        }

        .dashboard-kpi-label {
            margin: 0;
            font-size: 0.77rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            color: var(--ink-soft);
            font-weight: 700;
        }

        .dashboard-kpi-value {
            margin: 0.25rem 0 0;
            font-family: 'DM Serif Display', serif;
            font-size: 2rem;
            line-height: 1;
            color: #1b2e45;
        }

        .dashboard-panels {
            display: grid;
            gap: 0.95rem;
            grid-template-columns: 1.2fr 1fr;
        }

        .dashboard-list {
            display: grid;
            gap: 0.55rem;
            margin-top: 0.75rem;
        }

        .dashboard-person {
            border: 1px solid var(--line);
            border-radius: 0.75rem;
            padding: 0.62rem 0.7rem;
            background: rgba(255, 255, 255, 0.92);
        }

        .dashboard-person-name {
            margin: 0;
            color: var(--ink);
            font-size: 0.9rem;
            font-weight: 700;
        }

        .dashboard-person-email {
            margin: 0.12rem 0 0;
            color: var(--ink-soft);
            font-size: 0.82rem;
            word-break: break-word;
        }

        .dashboard-actions {
            display: grid;
            gap: 0.6rem;
            margin-top: 0.8rem;
        }

        .dashboard-actions .link-btn {
            justify-content: center;
            width: 100%;
        }

        @media (max-width: 1080px) {
            .dashboard-kpis {
                grid-template-columns: 1fr;
            }

            .dashboard-panels {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <div class="dashboard-layout">
        <section class="dashboard-hero">
            <div class="page-header">
                <div>
                    <h1>Dashboard</h1>
                    <p class="page-subtitle">Schneller Überblick über Personen, Aktionen und Organisation.</p>
                </div>
                <span class="badge enabled"><i class="fas fa-bolt"></i> Live</span>
            </div>

            <div class="dashboard-kpis">
                <article class="dashboard-kpi">
                    <p class="dashboard-kpi-label">Personen gesamt</p>
                    <p class="dashboard-kpi-value">{{ persons|length }}</p>
                </article>
                <article class="dashboard-kpi">
                    <p class="dashboard-kpi-label">Organisation</p>
                    <p class="dashboard-kpi-value" style="font-size: 1.35rem;">
                        {% if app.user.getSelectedOrganisation() %}
                            {{ app.user.getSelectedOrganisation().name }}
                        {% else %}
                            Keine Auswahl
                        {% endif %}
                    </p>
                </article>
                <article class="dashboard-kpi">
                    <p class="dashboard-kpi-label">Status</p>
                    <p class="dashboard-kpi-value" style="font-size: 1.35rem;">Bereit</p>
                </article>
            </div>
        </section>

        <section class="dashboard-panels">
            <div class="admin-form-card">
                <div class="page-header">
                    <div>
                        <h2>Stammdaten Vorschau</h2>
                        <p class="page-subtitle">Die ersten Kontakte aus deinem aktuellen Datenbestand.</p>
                    </div>
                    <a class="link-btn" href="{{ path('admin_person_list') }}">
                        <i class="fas fa-address-book"></i> Alle anzeigen
                    </a>
                </div>

                {% if persons is empty %}
                    <div class="empty-state">Noch keine Personen vorhanden.</div>
                {% else %}
                    <div class="dashboard-list">
                        {% for person in persons|slice(0, 8) %}
                            <article class="dashboard-person">
                                <p class="dashboard-person-name">{{ person.firstname }} {{ person.lastname }}</p>
                                <p class="dashboard-person-email">{{ person.email ?: 'Keine E-Mail hinterlegt' }}</p>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="admin-form-card">
                <div class="page-header">
                    <div>
                        <h2>Schnellaktionen</h2>
                        <p class="page-subtitle">Direkte Einstiege für die häufigsten Aufgaben.</p>
                    </div>
                </div>

                <div class="dashboard-actions">
                    <a class="link-btn primary" href="{{ path('admin_mission_create') }}"><i class="fas fa-plus-circle"></i> Einsatz erstellen</a>
                    <a class="link-btn" href="{{ path('admin_project_list') }}"><i class="fas fa-layer-group"></i> Projekte öffnen</a>
                    <a class="link-btn" href="{{ path('admin_person_list') }}"><i class="fas fa-users"></i> Personen verwalten</a>
                    <a class="link-btn" href="{{ path('admin_log_list') }}"><i class="fas fa-stream"></i> Logs ansehen</a>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
