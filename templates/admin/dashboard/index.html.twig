{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block main %}
    <style>
        .dashboard-layout {
            display: grid;
            gap: 0.95rem;
        }

        .dashboard-hero {
            border: 1px solid var(--line);
            border-radius: 0.95rem;
            padding: 1rem;
            background:
                radial-gradient(circle at 82% 12%, rgba(86, 134, 200, 0.16), transparent 46%),
                radial-gradient(circle at 18% 78%, rgba(222, 90, 42, 0.16), transparent 48%),
                rgba(255, 255, 255, 0.88);
        }

        .dashboard-kpis {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .dashboard-kpi {
            border: 1px solid var(--line);
            border-radius: 0.85rem;
            padding: 0.8rem;
            background: rgba(255, 255, 255, 0.9);
        }

        .dashboard-kpi-label {
            margin: 0;
            font-size: 0.77rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            color: var(--ink-soft);
            font-weight: 700;
        }

        .dashboard-label-with-tooltip {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
        }

        .dashboard-tooltip {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 1rem;
            height: 1rem;
            border-radius: 999px;
            border: 1px solid var(--line);
            color: var(--ink-soft);
            background: rgba(255, 255, 255, 0.9);
            font-size: 0.7rem;
            cursor: help;
        }

        .dashboard-tooltip-text {
            position: absolute;
            left: 50%;
            bottom: calc(100% + 0.45rem);
            transform: translateX(-50%);
            width: min(18rem, 70vw);
            padding: 0.5rem 0.6rem;
            border-radius: 0.65rem;
            border: 1px solid var(--line);
            background: rgba(29, 42, 53, 0.96);
            color: #fff;
            font-size: 0.72rem;
            line-height: 1.35;
            text-transform: none;
            letter-spacing: normal;
            font-weight: 600;
            box-shadow: 0 10px 30px rgba(29, 42, 53, 0.18);
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: opacity 120ms ease, visibility 120ms ease;
            z-index: 10;
        }

        .dashboard-tooltip:hover .dashboard-tooltip-text,
        .dashboard-tooltip:focus .dashboard-tooltip-text,
        .dashboard-tooltip:focus-visible .dashboard-tooltip-text {
            opacity: 1;
            visibility: visible;
        }

        .dashboard-project-stats-wrap {
            overflow-x: auto;
            overflow-y: visible;
        }

        .dashboard-kpi-value {
            margin: 0.25rem 0 0;
            font-family: 'DM Serif Display', serif;
            font-size: 2rem;
            line-height: 1;
            color: #1b2e45;
        }

        .dashboard-panels {
            display: grid;
            gap: 0.95rem;
            grid-template-columns: 1.2fr 1fr;
        }

        .dashboard-list {
            display: grid;
            gap: 0.55rem;
            margin-top: 0.75rem;
        }

        .dashboard-person {
            border: 1px solid var(--line);
            border-radius: 0.75rem;
            padding: 0.62rem 0.7rem;
            background: rgba(255, 255, 255, 0.92);
        }

        .dashboard-person-name {
            margin: 0;
            color: var(--ink);
            font-size: 0.9rem;
            font-weight: 700;
        }

        .dashboard-person-email {
            margin: 0.12rem 0 0;
            color: var(--ink-soft);
            font-size: 0.82rem;
            word-break: break-word;
        }

        .dashboard-actions {
            display: grid;
            gap: 0.6rem;
            margin-top: 0.8rem;
        }

        .dashboard-actions .link-btn {
            justify-content: center;
            width: 100%;
        }

        @media (max-width: 1080px) {
            .dashboard-kpis {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .dashboard-panels {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .dashboard-kpis {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <div class="dashboard-layout">
        <section class="dashboard-hero">
            <div class="page-header">
                <div>
                    <h1>Dashboard</h1>
                    <p class="page-subtitle">Schneller Überblick über Personen, Aktionen und Organisation.</p>
                </div>
                <span class="badge enabled"><i class="fas fa-bolt"></i> Live</span>
            </div>

            <div class="dashboard-kpis">
                <article class="dashboard-kpi">
                    <p class="dashboard-kpi-label">Personen gesamt</p>
                    <p class="dashboard-kpi-value">{{ persons|length }}</p>
                </article>
                <article class="dashboard-kpi">
                    <p class="dashboard-kpi-label">Organisation</p>
                    <p class="dashboard-kpi-value" style="font-size: 1.35rem;">
                        {% if app.user.getSelectedOrganisation() %}
                            {{ app.user.getSelectedOrganisation().name }}
                        {% else %}
                            Keine Auswahl
                        {% endif %}
                    </p>
                </article>
                <article class="dashboard-kpi">
                    <p class="dashboard-kpi-label">
                            <span class="dashboard-label-with-tooltip">
                                Bereits angemeldet
                            <span class="dashboard-tooltip" tabindex="0" aria-label="{{ activeMissionCountTooltip }}">
                                i
                                <span class="dashboard-tooltip-text">{{ activeMissionCountTooltip }}</span>
                            </span>
                        </span>
                    </p>
                    <p class="dashboard-kpi-value">{{ totalEnrolledPersons }}</p>
                </article>
                <article class="dashboard-kpi">
                    <p class="dashboard-kpi-label">
                        <span class="dashboard-label-with-tooltip">
                            Offene Anmeldungen
                            <span class="dashboard-tooltip" tabindex="0" aria-label="{{ activeMissionCountTooltip }}">
                                i
                                <span class="dashboard-tooltip-text">{{ activeMissionCountTooltip }}</span>
                            </span>
                        </span>
                    </p>
                    <p class="dashboard-kpi-value">{{ totalOpenEnrollments }}</p>
                </article>
            </div>
        </section>

        <section class="dashboard-panels">
            <div class="admin-form-card">
                <div class="page-header">
                    <div>
                        <h2>Stammdaten Vorschau</h2>
                        <p class="page-subtitle">Die ersten Kontakte aus deinem aktuellen Datenbestand.</p>
                    </div>
                    <a class="link-btn" href="{{ path('admin_person_list') }}">
                        <i class="fas fa-address-book"></i> Alle anzeigen
                    </a>
                </div>

                {% if persons is empty %}
                    <div class="empty-state">Noch keine Personen vorhanden.</div>
                {% else %}
                    <div class="dashboard-list">
                        {% for person in persons|slice(0, 8) %}
                            <article class="dashboard-person">
                                <p class="dashboard-person-name">{{ person.firstname }} {{ person.lastname }}</p>
                                <p class="dashboard-person-email">{{ person.email ?: 'Keine E-Mail hinterlegt' }}</p>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="admin-form-card">
                <div class="page-header">
                    <div>
                        <h2>Schnellaktionen</h2>
                        <p class="page-subtitle">Direkte Einstiege für die häufigsten Aufgaben.</p>
                    </div>
                </div>

                <div class="dashboard-actions">
                    <a class="link-btn primary" href="{{ path('admin_mission_create') }}"><i class="fas fa-plus-circle"></i> Einsatz erstellen</a>
                    <a class="link-btn" href="{{ path('admin_project_list') }}"><i class="fas fa-layer-group"></i> Projekte öffnen</a>
                    <a class="link-btn" href="{{ path('admin_person_list') }}"><i class="fas fa-users"></i> Personen verwalten</a>
                    <a class="link-btn" href="{{ path('admin_log_list') }}"><i class="fas fa-stream"></i> Logs ansehen</a>
                </div>
            </div>
        </section>

        <section class="admin-form-card">
            <div class="page-header">
                <div>
                    <h2>Projektübersicht Anmeldungen</h2>
                    <p class="page-subtitle">Angemeldete Personen und noch offene Plätze pro Projekt.</p>
                </div>
            </div>

            {% if projectStats is empty %}
                <div class="empty-state">Keine Projekte für die aktuell gewählte Organisation gefunden.</div>
            {% else %}
                <div class="table-wrap dashboard-project-stats-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Projekt</th>
                                <th>
                                    <span class="dashboard-label-with-tooltip">
                                        Total angemeldet
                                        <span class="dashboard-tooltip" tabindex="0" aria-label="{{ activeMissionCountTooltip }}">
                                            i
                                            <span class="dashboard-tooltip-text">{{ activeMissionCountTooltip }}</span>
                                        </span>
                                    </span>
                                </th>
                                <th>
                                    <span class="dashboard-label-with-tooltip">
                                        Offene Anmeldungen
                                        <span class="dashboard-tooltip" tabindex="0" aria-label="{{ activeMissionCountTooltip }}">
                                            i
                                            <span class="dashboard-tooltip-text">{{ activeMissionCountTooltip }}</span>
                                        </span>
                                    </span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in projectStats %}
                                <tr>
                                    <td>{{ row.project.name }}</td>
                                    <td>{{ row.enrolledPersons }}</td>
                                    <td>{{ row.openEnrollments }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>
    </div>
{% endblock %}
