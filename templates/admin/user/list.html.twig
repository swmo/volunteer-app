{% extends 'admin/base.html.twig' %}

{% block title %}Benutzer{% endblock %}

{% block main %}
<div class="admin-form-card">
  <div class="page-header">
    <div>
      <h1>Benutzer</h1>
      <p class="page-subtitle">Alle Benutzerkonten dieser Organisation.</p>
    </div>
  </div>

  {% if users is empty %}
    <div class="empty-state">Keine Benutzer vorhanden.</div>
  {% else %}
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>E-Mail</th>
          </tr>
        </thead>
        <tbody>
          {% for user in users %}
            <tr>
              <td>{{ user.getAppuser().email }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
{% endblock %}
