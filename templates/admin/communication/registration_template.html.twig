{% extends 'admin/base.html.twig' %}

{% block title %}Kommunikation{% endblock %}

{% block main %}
<div class="admin-form-card">
  <div class="form-header">
    <h1>Kommunikation</h1>
    <p class="form-help">Template für die Registrierungs-E-Mail (Twig + HTML).</p>
  </div>

  {{ form_start(form) }}
    {{ form_row(form.subject) }}
    {{ form_row(form.body) }}
    {{ form_row(form.save) }}
  {{ form_end(form) }}
</div>
{% endblock %}

