{% extends 'admin/base.html.twig' %}

{% block title %}Log{% endblock %}

{% block main %}
<div class="admin-form-card">
  <div class="page-header">
    <div>
      <h1>Log</h1>
      <p class="page-subtitle">Historie aller erfassten Änderungen.</p>
    </div>
  </div>

  {% if logEntries is empty %}
    <div class="empty-state">Keine Logeinträge vorhanden.</div>
  {% else %}
    <div class="table-wrap">
      <table class="admin-log-table">
        <thead>
          <tr>
            <th>Datum</th>
            <th>Benutzer</th>
            <th>ObjektClass</th>
            <th>ObjektId</th>
            <th>Action</th>
            <th>Version</th>
            <th>Daten</th>
          </tr>
        </thead>
        <tbody>
          {% for logEntry in logEntries %}
            <tr>
              <td>{{ logEntry.loggedAt|date('Y-m-d H:i') }}</td>
              <td>{{ logEntry.username }}</td>
              <td>{{ logEntry.objectClass }}</td>
              <td>{{ logEntry.objectId }}</td>
              <td>{{ logEntry.action }}</td>
              <td>{{ logEntry.version }}</td>
              <td><pre class="json-preview">{{ logEntry.data|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
{% endblock %}
