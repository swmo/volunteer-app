APP_DIR := volunteer-app
ENV_FILE := .env.prod
COMPOSE_FILE := $(APP_DIR)/docker-compose.prod.yml
COMPOSE := docker compose --env-file $(ENV_FILE) --project-directory $(APP_DIR) -f $(COMPOSE_FILE)

.PHONY: prod-init prod-up prod-update prod-migrate prod-bootstrap prod-logs

prod-init:
	@set -a; . ./$(ENV_FILE); set +a; \
		mkdir -p "$$POSTGRES_DATA_DIR"
	$(COMPOSE) up -d postgres
	$(COMPOSE) up --build -d
	$(COMPOSE) exec app php bin/console doctrine:migrations:migrate --no-interaction
	$(COMPOSE) exec app php bin/console app:bootstrap-production --no-interaction

prod-up:
	$(COMPOSE) up --build -d

prod-update:
	cd $(APP_DIR) && git pull
	$(COMPOSE) up --build -d
	$(COMPOSE) exec app php bin/console doctrine:migrations:migrate --no-interaction

prod-migrate:
	$(COMPOSE) exec app php bin/console doctrine:migrations:migrate --no-interaction

prod-bootstrap:
	$(COMPOSE) exec app php bin/console app:bootstrap-production --no-interaction

prod-logs:
	$(COMPOSE) logs -f
