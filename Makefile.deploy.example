APP_DIR := volunteer-app
ENV_FILE := .env.prod
COMPOSE_FILE := $(APP_DIR)/docker-compose.prod.yml
COMPOSE := docker compose --env-file $(ENV_FILE) --project-directory $(APP_DIR) -f $(COMPOSE_FILE)
BACKUP_DIR := backups

.PHONY: prod-init prod-up prod-update prod-migrate prod-bootstrap prod-backup prod-logs

prod-init:
	@mkdir -p "$$(grep '^POSTGRES_DATA_DIR=' $(ENV_FILE) | sed 's/^POSTGRES_DATA_DIR=//')"
	$(COMPOSE) up -d postgres
	$(COMPOSE) up --build -d
	@set -e; \
		TABLE_COUNT=$$($(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" psql -U "$$POSTGRES_USER" -d "$$POSTGRES_DB" -tAc "SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = '\''public'\''"'); \
		APPUSER_EXISTS=$$($(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" psql -U "$$POSTGRES_USER" -d "$$POSTGRES_DB" -tAc "SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = '\''public'\'' AND table_name = '\''appuser'\''"'); \
		if [ "$$APPUSER_EXISTS" = "1" ]; then \
			echo "Existing application schema detected, skipping doctrine:schema:create."; \
		elif [ "$$TABLE_COUNT" = "0" ]; then \
			$(COMPOSE) exec app php bin/console doctrine:schema:create --no-interaction; \
			$(COMPOSE) exec app php bin/console doctrine:migrations:sync-metadata-storage --no-interaction; \
			$(COMPOSE) exec app php bin/console doctrine:migrations:version --add --all --no-interaction; \
		else \
			echo "Database is partially initialized. Clean POSTGRES_DATA_DIR or restore a known-good backup before rerunning prod-init."; \
			exit 1; \
		fi
	$(COMPOSE) exec app php bin/console app:bootstrap-production --no-interaction

prod-up:
	$(COMPOSE) up --build -d

prod-update:
	cd $(APP_DIR) && git pull
	cp $(APP_DIR)/Makefile.deploy.example Makefile
	$(COMPOSE) up --build -d
	$(COMPOSE) exec app php bin/console doctrine:migrations:migrate --no-interaction

prod-migrate:
	$(COMPOSE) exec app php bin/console doctrine:migrations:migrate --no-interaction

prod-bootstrap:
	$(COMPOSE) exec app php bin/console app:bootstrap-production --no-interaction

prod-backup:
	@mkdir -p $(BACKUP_DIR)
	@set -e; \
		WEEKDAY=$$(date +%A | tr '[:upper:]' '[:lower:]'); \
		$$(grep '^POSTGRES_PASSWORD=' $(ENV_FILE) >/dev/null); \
		$(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" pg_dump -U "$$POSTGRES_USER" -d "$$POSTGRES_DB"' > $(BACKUP_DIR)/postgres-$${WEEKDAY}.sql

prod-logs:
	$(COMPOSE) logs -f
