APP_DIR := volunteer-app
ENV_FILE := .env.prod
COMPOSE_FILE := $(APP_DIR)/docker-compose.prod.yml
COMPOSE := docker compose --env-file $(ENV_FILE) --project-directory $(APP_DIR) -f $(COMPOSE_FILE)
APP_EXEC := $(COMPOSE) exec -u nobody app
BACKUP_DIR := backups
MAINTENANCE_DB := template1

.PHONY: prod-up prod-down prod-update prod-migrate prod-bootstrap prod-backup prod-restore prod-logs

prod-up:
	$(COMPOSE) up  -d

prod-down:
	$(COMPOSE) down

prod-update:
	cd $(APP_DIR) && git pull
	cp $(APP_DIR)/Makefile.deploy.example Makefile
	$(COMPOSE) up --build -d
	$(APP_EXEC) php bin/console doctrine:migrations:migrate --no-interaction

prod-migrate:
	$(APP_EXEC) php bin/console doctrine:migrations:migrate --no-interaction

prod-bootstrap:
	$(APP_EXEC) php bin/console app:bootstrap-production --no-interaction

prod-backup:
	@mkdir -p $(BACKUP_DIR)
	@set -e; \
		WEEKDAY=$$(date +%A | tr '[:upper:]' '[:lower:]'); \
		$$(grep '^POSTGRES_PASSWORD=' $(ENV_FILE) >/dev/null); \
		$(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" pg_dump -U "$$POSTGRES_USER" -d "$$POSTGRES_DB"' > $(BACKUP_DIR)/postgres-$${WEEKDAY}.sql

prod-restore:
	@test -n "$(DUMP)" || (echo "Usage: make prod-restore DUMP=backups/postgres-monday.sql" && exit 1)
	@test -f "$(DUMP)" || (echo "Dump file not found: $(DUMP)" && exit 1)
	$(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" psql -U "$$POSTGRES_USER" -d "$(MAINTENANCE_DB)" -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '\''$$POSTGRES_DB'\'' AND pid <> pg_backend_pid();"'
	$(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" psql -U "$$POSTGRES_USER" -d "$(MAINTENANCE_DB)" -c "DROP DATABASE IF EXISTS \"$$POSTGRES_DB\";"'
	$(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" psql -U "$$POSTGRES_USER" -d "$(MAINTENANCE_DB)" -c "CREATE DATABASE \"$$POSTGRES_DB\";"'
	$(COMPOSE) exec -T postgres sh -lc 'PGPASSWORD="$$POSTGRES_PASSWORD" psql -U "$$POSTGRES_USER" -d "$$POSTGRES_DB"' < $(DUMP)

prod-logs:
	$(COMPOSE) logs -f
